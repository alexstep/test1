    "@nestjs/testing": "^10.4.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "bun-types": "^1.3.14",
    "pino-pretty": "^11.2.0",
    "typescript": "^5.6.0"
  }
