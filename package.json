    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-fastify": "^10.4.0",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/throttler": "^6",
    "@nestjs/typeorm": "^10.0.2",
    "@scalar/nestjs-api-reference": "^1.2.10",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "fastify": "^4.28.1",
